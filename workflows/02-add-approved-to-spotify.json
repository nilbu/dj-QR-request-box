            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "c7763e65-b629-4eda-a1dc-d74c3e005f14",
              "leftValue": "={{ $json.add_failed }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
