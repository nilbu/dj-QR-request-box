    {
      "parameters": {
        "jsCode": "const request = $('Prepare request data and default status NEW').first().json;\nconst response = $json;\nconst content = response.choices?.[0]?.message?.content || response.body?.choices?.[0]?.message?.content || '';\nlet ai = {};\n\ntry {\n  ai = typeof content === 'string' ? JSON.parse(content) : content;\n} catch (error) {\n  ai = {};\n}\n\nconst aiTitle = String(ai.AI_title || ai.title || request.form_title || '').trim();\nconst aiArtist = String(ai.AI_artist || ai.artist || request.form_artist || '').trim();\nlet spotifyQuery = String(ai.spotify_query || '').trim();\n\nif (!spotifyQuery) {\n  spotifyQuery = [aiTitle, aiArtist].filter(Boolean).join(' ');\n}\n\nreturn [{\n  json: {\n    ...request,\n    AI_title: aiTitle,\n    AI_artist: aiArtist,\n    spotify_query: spotifyQuery,\n    ai_raw_response: content\n  }\n}];"
      },
      "id": "7fa67dce-40ff-41e3-bd04-f1e89c6d5fd1",
      "name": "Parse OpenAI JSON normalization",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1340,
        -40
      ]
    },
    {
      "parameters": {
        "url": "https://api.spotify.com/v1/search",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "spotifyOAuth2Api",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "q",
              "value": "={{ $json.spotify_query }}"
            },
            {
              "name": "type",
              "value": "track"
            },
