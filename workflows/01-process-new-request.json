              "responseFormat": "json"
            }
          }
        }
      },
      "id": "800bd3dc-7425-442c-b390-f7fab558d62b",
      "name": "OpenAI - normalize title artist and query",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1060,
        -40
      ],
      "credentials": {
