      "id": "2eeb16c0-2710-4d77-a2e0-701c0fe7dbf8",
      "name": "Spotify - search tracks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1620,
        -40
      ],
      "credentials": {
        "spotifyOAuth2Api": {
          "id": "__SPOTIFY_CREDENTIAL_ID__",
          "name": "__SPOTIFY_CREDENTIAL_NAME__"
        }
      }
