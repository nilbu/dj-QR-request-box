          "__rl": true,
          "value": "gpt-4.1-mini",
          "mode": "list",
          "cachedResultName": "GPT-4.1-MINI"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You normalize music requests for a DJ. Return only a strict JSON object with keys AI_title, AI_artist, spotify_query. Do not invent an artist when it is unknown. Keep values concise."
            },
            {
              "content": "=Normalize this music request.\n\nTitle: {{ $('Prepare request - map form fields').item.json.form_title }}\nArtist: {{ $('Prepare request - map form fields').item.json.form_artist }}\nRequester/table: {{ $('Prepare request - map form fields').item.json.requester_name }}\nComment: {{ $('Prepare request - map form fields').item.json.comment }}\n\nReturn JSON like:\n{\"AI_title\":\"...\",\"AI_artist\":\"...\",\"spotify_query\":\"...\"}"
            }
          ]
        },
        "jsonOutput": true,
        "options": {
          "temperature": 0.1
        }
      },
      "id": "800bd3dc-7425-442c-b390-f7fab558d62b",
      "name": "OpenAI - normalize request to JSON",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        980,
        -80
      ],
      "credentials": {
        "openAiApi": {
          "name": "__OPENAI_CREDENTIAL_NAME__"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const request = $('Prepare request - map form fields').first().json;\nconst response = $json;\nconst content = response.message?.content ?? response.text ?? response.output ?? response.content ?? response;\nlet ai = {};\n\nif (typeof content === 'string') {\n  try {\n    ai = JSON.parse(content);\n  } catch (error) {\n    ai = {};\n  }\n} else if (content && typeof content === 'object') {\n  ai = content;\n}\n\nconst aiTitle = String(ai.AI_title || ai.title || request.form_title || '').trim();\nconst aiArtist = String(ai.AI_artist || ai.artist || request.form_artist || '').trim();\nlet spotifyQuery = String(ai.spotify_query || ai.query || '').trim();\n\nif (!spotifyQuery) {\n  spotifyQuery = [aiTitle, aiArtist].filter(Boolean).join(' ');\n}\n\nreturn [{\n  json: {\n    ...request,\n    AI_title: aiTitle,\n    AI_artist: aiArtist,\n    spotify_query: spotifyQuery,\n    confidence: 0,\n    ai_raw_response: typeof content === 'string' ? content : JSON.stringify(content)\n  }\n}];"
      },
      "id": "7fa67dce-40ff-41e3-bd04-f1e89c6d5fd1",
      "name": "Parse OpenAI normalization",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
