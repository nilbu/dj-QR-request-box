    {
      "parameters": {
        "jsCode": "const row = $json;\n\nfunction firstValue(keys) {\n  for (const key of keys) {\n    const value = row[key];\n    if (value !== undefined && value !== null && String(value).trim() !== '') {\n      return String(value).trim();\n    }\n  }\n  return '';\n}\n\nconst rowNumber = row.row_number || row.rowNumber || row.__rowNum__ || row._rowNumber || row['Row Number'] || '';\nconst originalStatus = firstValue(['status', 'Status']);\nconst songTitle = firstValue(['song_title_raw', 'Song title', 'Song Title', 'title', 'Title', 'Tytul utworu']);\nconst artist = firstValue(['artist_raw', 'Artist', 'artist', 'Wykonawca']);\nconst requester = firstValue(['requester_name', 'Your name', 'Name', 'Imie', 'Stolik', 'Table']);\nconst dedication = firstValue(['dedication', 'Dedication', 'Dedykacja', 'note', 'Note']);\n\nconst normalizedStatus = originalStatus || 'NEW';\nconst shouldProcess = normalizedStatus === 'NEW';\n\nreturn [{\n  json: {\n    ...row,\n    row_number: rowNumber,\n    form_title: songTitle,\n    form_artist: artist,\n    requester_name: requester,\n    dedication,\n    status_original: originalStatus,\n    status: normalizedStatus,\n    should_process: shouldProcess,\n    has_required_title: songTitle.length > 0,\n    spotify_playlist_id_placeholder: '__SPOTIFY_PLAYLIST_ID__'\n  }\n}];"
      },
