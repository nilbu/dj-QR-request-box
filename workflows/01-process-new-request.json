    {
      "parameters": {
        "jsCode": "function firstValue(row, keys) {\n  for (const key of keys) {\n    const value = row[key];\n    if (value !== undefined && value !== null && String(value).trim() !== '') {\n      return String(value).trim();\n    }\n  }\n  return '';\n}\n\nreturn $input.all().filter((item) => {\n  const row = item.json;\n  const status = firstValue(row, ['status', 'Status']);\n  const timestamp = firstValue(row, ['Sygnatura czasowa', 'Timestamp', 'timestamp']);\n  return status === '' && timestamp !== '';\n});"
      },
      "id": "9cadb087-b438-4016-9d59-feb54caa2d06",
      "name": "Filter - only empty status rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -160,
        120
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "49c3f917-2743-4da3-8a1d-841af0a69044",
      "name": "Loop - process one request row",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        120,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "const row = $json;\n\nfunction firstValue(keys) {\n  for (const key of keys) {\n    const value = row[key];\n    if (value !== undefined && value !== null && String(value).trim() !== '') {\n      return String(value).trim();\n    }\n  }\n  return '';\n}\n\nconst timestamp = firstValue(['Sygnatura czasowa', 'Timestamp', 'timestamp']);\nconst title = firstValue(['Tytuł utworu', 'Tytul utworu', 'song_title_raw', 'Song title', 'Song Title', 'title', 'Title']);\nconst artist = firstValue(['Wykonawca', 'artist_raw', 'Artist', 'artist']);\nconst requester = firstValue(['Imię / stolik', 'Imie / stolik', 'requester_name', 'Your name', 'Name', 'Imie', 'Stolik', 'Table']);\nconst comment = firstValue(['Komentarz', 'komentarz', 'dedication', 'Dedication', 'Dedykacja', 'comment', 'Comment']);\n\nreturn [{\n  json: {\n    ...row,\n    timestamp_signature: timestamp,\n    form_title: title,\n    form_artist: artist,\n    requester_name: requester,\n    comment,\n    has_required_title: title.length > 0\n  }\n}];"
      },
      "id": "7b573af8-9b1d-4710-8b15-640df2c58258",
      "name": "Prepare request - map form fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        20
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "5ac6acb7-ce1b-458d-b08f-ff33a77b7d96",
              "leftValue": "={{ $json.has_required_title }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "1704ca16-9979-4a31-bc5a-71caa966ea3c",
      "name": "IF - title exists",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        700,
        20
      ]
    },
    {
      "parameters": {
