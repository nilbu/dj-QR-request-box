    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: 'gpt-4.1-mini', response_format: { type: 'json_object' }, messages: [ { role: 'system', content: 'You normalize music requests for a DJ. Return only valid JSON with keys AI_title, AI_artist, spotify_query. Do not invent an artist when it is unknown. Keep values concise.' }, { role: 'user', content: 'Normalize this request. Title: ' + $('Prepare request data and default status NEW').first().json.form_title + '\\nArtist: ' + ($('Prepare request data and default status NEW').first().json.form_artist || '') + '\\nRequester/table: ' + ($('Prepare request data and default status NEW').first().json.requester_name || '') + '\\nDedication: ' + ($('Prepare request data and default status NEW').first().json.dedication || '') } ], temperature: 0.1 } }}",
        "options": {
