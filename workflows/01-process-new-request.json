    {
      "parameters": {
        "jsCode": "const request = $('Parse OpenAI JSON normalization').first().json;\nconst items = $json.tracks?.items || $json.body?.tracks?.items || [];\n\nfunction clean(value) {\n  return String(value || '')\n    .toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[^a-z0-9 ]/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction scoreTrack(track) {\n  const titleNeedle = clean(request.AI_title || request.form_title);\n  const artistNeedle = clean(request.AI_artist || request.form_artist);\n  const trackTitle = clean(track.name);\n  const trackArtists = clean((track.artists || []).map((artist) => artist.name).join(' '));\n\n  let score = 0;\n  if (titleNeedle && trackTitle === titleNeedle) score += 0.55;\n  else if (titleNeedle && trackTitle.includes(titleNeedle)) score += 0.42;\n  else if (titleNeedle && titleNeedle.includes(trackTitle)) score += 0.32;\n\n  if (artistNeedle && trackArtists.includes(artistNeedle)) score += 0.35;\n  else if (!artistNeedle) score += 0.15;\n\n  const query = clean(request.spotify_query);\n  if (query && clean(track.name + ' ' + trackArtists).includes(query)) score += 0.1;\n\n  const badVersion = /karaoke|tribute|cover|instrumental|Originally Performed/i.test(track.name + ' ' + ((track.album || {}).name || ''));\n  if (badVersion && !/karaoke|cover|instrumental/i.test(request.form_title + ' ' + request.dedication)) score -= 0.2;\n\n  return Math.max(0, Math.min(1, Number(score.toFixed(2))));\n}\n\nlet best = null;\nlet confidence = 0;\nfor (const track of items) {\n  const score = scoreTrack(track);\n  if (score > confidence) {\n    confidence = score;\n    best = track;\n  }\n}\n\nconst found = Boolean(best && best.uri && confidence >= 0.65);\nconst artistName = best?.artists?.map((artist) => artist.name).join(', ') || '';\n\nreturn [{\n  json: {\n    ...request,\n    spotify_track_name: found ? best.name : '',\n    spotify_artist: found ? artistName : '',\n    spotify_url: found ? (best.external_urls?.spotify || '') : '',\n    spotify_uri: found ? best.uri : '',\n    confidence,\n    status: found ? 'FOUND' : 'NOT_FOUND',\n    dj_note: found\n      ? 'Found by Spotify Search. DJ must manually approve before playlist workflow can add it.'\n      : `No sensible Spotify result for query: ${request.spotify_query}`\n  }\n}];"
      },
      "id": "d9a15a02-cd87-4d8f-9204-53e37957a33f",
      "name": "Evaluate Spotify result and confidence",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1900,
        -40
      ]
