    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const request = $('Parse OpenAI normalization').first().json;\nconst queryItems = $('Spotify - search tracks by spotify_query').all().map((item) => item.json.track || item.json).filter(Boolean);\nconst titleItems = $('Spotify - fallback search by AI_title').all().map((item) => item.json.track || item.json).filter(Boolean);\n\nfunction clean(value) {\n  return String(value || '')\n    .toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[^a-z0-9 ]/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction artistsText(track) {\n  return (track.artists || []).map((artist) => artist.name || artist).filter(Boolean).join(', ');\n}\n\nfunction spotifyUrl(track) {\n  return track.external_urls?.spotify || track.externalUrls?.spotify || track.url || '';\n}\n\nfunction spotifyUri(track) {\n  if (track.uri) return track.uri;\n  if (track.id) return `spotify:track:${track.id}`;\n  return '';\n}\n\nfunction trackKey(track) {\n  return spotifyUri(track) || track.id || `${clean(track.name)}:${clean(artistsText(track))}`;\n}\n\nconst seen = new Set();\nconst spotifyItems = [];\nfor (const track of [...queryItems, ...titleItems]) {\n  const key = trackKey(track);\n  if (!key || seen.has(key)) continue;\n  seen.add(key);\n  spotifyItems.push(track);\n}\n\nfunction scoreTrack(track) {\n  const wantedTitle = clean(request.AI_title || request.form_title);\n  const wantedArtist = clean(request.AI_artist || request.form_artist);\n  const trackTitle = clean(track.name);\n  const trackArtists = clean(artistsText(track));\n  let score = 0;\n\n  if (wantedTitle && trackTitle === wantedTitle) score += 0.55;\n  else if (wantedTitle && trackTitle.includes(wantedTitle)) score += 0.42;\n  else if (wantedTitle && wantedTitle.includes(trackTitle)) score += 0.32;\n\n  if (wantedArtist && trackArtists.includes(wantedArtist)) score += 0.35;\n  else if (!wantedArtist) score += 0.15;\n\n  const query = clean(request.spotify_query);\n  if (query && clean(`${track.name} ${artistsText(track)}`).includes(query)) score += 0.1;\n\n  const versionText = `${track.name || ''} ${track.album?.name || ''}`;\n  const unwantedVersion = /karaoke|tribute|cover|instrumental|originally performed/i.test(versionText);\n  const requestedVersion = /karaoke|cover|instrumental|tribute/i.test(`${request.form_title} ${request.comment}`);\n  if (unwantedVersion && !requestedVersion) score -= 0.2;\n\n  return Math.max(0, Math.min(1, Number(score.toFixed(2))));\n}\n\nlet best = null;\nlet confidence = 0;\nfor (const track of spotifyItems) {\n  const score = scoreTrack(track);\n  if (score > confidence) {\n    confidence = score;\n    best = track;\n  }\n}\n\nconst found = Boolean(best && spotifyUri(best) && confidence >= 0.65);\nconst searchSummary = `query results: ${queryItems.length}, title fallback results: ${titleItems.length}, unique tracks: ${spotifyItems.length}`;\n\nreturn [{\n  json: {\n    ...request,\n    spotify_track_name: found ? (best.name || '') : '',\n    spotify_artist: found ? artistsText(best) : '',\n    spotify_url: found ? spotifyUrl(best) : '',\n    spotify_uri: found ? spotifyUri(best) : '',\n    confidence,\n    status: found ? 'FOUND' : 'NOT_FOUND',\n    dj_note: found\n      ? `Found by Spotify fallback search. ${searchSummary}. DJ must manually approve before playlist workflow can add it.`\n      : `No sensible Spotify result after fallback search for query: ${request.spotify_query}; AI_title: ${request.AI_title}. ${searchSummary}.`\n  }\n}];"
      },
      "id": "d9a15a02-cd87-4d8f-9204-53e37957a33f",
      "name": "Evaluate Spotify results and confidence",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
